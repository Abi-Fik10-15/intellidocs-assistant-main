# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intellidocs

# LLM provider: openai | claude | gemini (switch without code changes)
LLM_PROVIDER=openai
LLM_REQUEST_TIMEOUT_MS=120000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CLAUDE_MODEL=claude-sonnet-4-20250514
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Embeddings: openai | gemini | mock (local dev, no API)
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIMENSIONS=1536

# Chunking
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# Retrieval
RETRIEVAL_TOP_K=5

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# n8n webhook (optional — triggers workflows on document ingest / chat)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
